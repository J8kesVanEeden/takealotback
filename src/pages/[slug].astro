---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import JsonLd from '../components/JsonLd.astro';
import { GITHUB_REPO_URL, LAST_REVIEWED } from '../data/content';
import { scanForCitations } from '../lib/citation-links';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props {
  page: CollectionEntry<'pages'>;
}

const { page } = Astro.props;
const { Content } = await page.render();

// Scan the markdown body for any cited statutes / cases / advisories /
// regulators we have a /citations/ page for; render as chips at the
// bottom of the page.
const sources = scanForCitations(page.body);

const title = page.data.metaTitle ?? `${page.data.title} · TakealotBack.com`;
const canonicalPath = `/${page.slug}`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://takealotback.com';
const canonical = `${siteUrl}${canonicalPath}`;

// JSON-LD: Article (educational commentary) + BreadcrumbList.
const article = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${canonical}#article`,
  headline: page.data.title,
  description: page.data.description,
  url: canonical,
  mainEntityOfPage: canonical,
  inLanguage: 'en-ZA',
  isAccessibleForFree: true,
  isPartOf: { '@id': `${siteUrl}/#website` },
  publisher: { '@id': 'https://www.milkmoonstudio.com/#organization' },
  author: { '@id': 'https://www.milkmoonstudio.com/#organization' },
  license: `${GITHUB_REPO_URL}/blob/main/CONTENT-LICENSE.md`,
  // Use the site's published review date as a best-available dateModified.
  // LAST_REVIEWED is in "YYYY.MM.DD" form; convert to ISO date for schema.
  dateModified: LAST_REVIEWED.replace(/\./g, '-'),
  datePublished: '2026-04-23',
  keywords: [
    'Consumer Protection Act',
    'CPA',
    'Takealot',
    'South African consumer rights',
    'online retail returns',
    'ECT Act',
    'POPIA',
  ].join(', '),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: page.data.title, item: canonical },
  ],
};
---
<Layout title={title} description={page.data.description} canonicalPath={canonicalPath}>
  <Fragment slot="head">
    <JsonLd data={article} />
    <JsonLd data={breadcrumb} />
  </Fragment>

  <Section id="deep-dive" label="Deep dive" tag="article">
    <nav class="tb-sub__crumbs" aria-label="Breadcrumb">
      <ol class="tb-sub__crumblist">
        <li><a href="/" class="mono tb-sub__crumb">Home</a></li>
        <li aria-current="page"><span class="mono tb-sub__crumb tb-sub__crumb--current">{page.data.title}</span></li>
      </ol>
    </nav>
    <div class="tb-sub">
      <h1 class="display h2 tb-sub__title">{page.data.title}</h1>
      <p class="lede tb-sub__lede">{page.data.description}</p>
      <hr class="tb-sub__rule" />
      <div class="prose tb-sub__prose">
        <Content />
      </div>

      {sources.length > 0 && (
        <div class="tb-sub__sources">
          <div class="mono slash-label tb-sub__sources-label">Sources cited on this page</div>
          <ul class="tb-sub__sources-list" aria-label="Source citations">
            {sources.map((s) => (
              <li><a href={s.url} class="tb-sub__source-link">{s.label}</a></li>
            ))}
          </ul>
        </div>
      )}

      <div class="tb-sub__foot">
        <a href="/" class="btn ghost">&larr; Back to the single page</a>
        <a href="/citations" class="btn ghost">All citations &rarr;</a>
      </div>
    </div>
  </Section>
</Layout>

<style>
  .tb-sub { max-width: 72ch; }
  .tb-sub__title { margin: 0 0 20px; max-width: 24ch; }
  .tb-sub__lede { margin: 0 0 32px; }
  .tb-sub__rule {
    height: 1px;
    background: var(--rule);
    border: 0;
    margin: 0 0 32px;
  }
  .tb-sub__prose { max-width: none; }
  /* Hide the markdown's own H1 since we render it above in the shell */
  .tb-sub__prose :global(h1) { display: none; }
  .tb-sub__foot {
    margin-top: 56px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tb-sub__sources {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px dashed var(--rule);
  }
  .tb-sub__sources-label {
    color: var(--ink);
    margin-bottom: 12px;
  }
  .tb-sub__sources-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tb-sub__source-link {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border: 1px solid var(--rule);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-soft);
    background: var(--paper-alt);
    text-decoration: none;
    transition: border-color 120ms ease, color 120ms ease, background 120ms ease;
  }
  .tb-sub__source-link:hover,
  .tb-sub__source-link:focus-visible {
    border-color: var(--ink);
    color: var(--ink);
    background: var(--paper-tint);
  }
  .tb-sub__crumbs { margin-bottom: 24px; }
  .tb-sub__crumblist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }
  .tb-sub__crumblist li { display: inline-flex; align-items: center; }
  .tb-sub__crumblist li + li::before {
    content: '/';
    color: var(--ink-faint);
    margin-right: 12px;
  }
  .tb-sub__crumb {
    color: var(--ink-muted);
    text-decoration: none;
  }
  .tb-sub__crumb--current { color: var(--ink); }
  a.tb-sub__crumb:hover { color: var(--accent); }
</style>
