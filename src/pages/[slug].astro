---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import JsonLd from '../components/JsonLd.astro';
import SourceChips from '../components/SourceChips.astro';
import { LAST_REVIEWED } from '../data/content';
import { scanForCitations } from '../lib/citation-links';
import { buildDeepDiveArticle, buildBreadcrumb } from '../lib/schema';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props {
  page: CollectionEntry<'pages'>;
}

const { page } = Astro.props;
const { Content } = await page.render();

// Scan the markdown body for any cited statutes / cases / advisories /
// regulators we have a /citations/ page for; render as chips at the
// bottom of the page.
const sources = scanForCitations(page.body);

const title = page.data.metaTitle ?? `${page.data.title} · TakealotBack.com`;
const canonicalPath = `/${page.slug}`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://takealotback.com';
const canonical = `${siteUrl}${canonicalPath}`;

// JSON-LD: Article (educational commentary) + BreadcrumbList. Schema
// shapes live in src/lib/schema.ts so any change to Article fields
// applies consistently across deep-dives + citation pages.
const article = buildDeepDiveArticle({
  canonical,
  title: page.data.title,
  description: page.data.description,
  datePublished: page.data.datePublished ?? '2026-04-23',
  dateModified: page.data.dateModified ?? LAST_REVIEWED.replace(/\./g, '-'),
});

const breadcrumb = buildBreadcrumb([
  { name: 'Home', url: `${siteUrl}/` },
  { name: page.data.title, url: canonical },
]);
---
<Layout title={title} description={page.data.description} canonicalPath={canonicalPath}>
  <Fragment slot="head">
    <JsonLd data={article} />
    <JsonLd data={breadcrumb} />
  </Fragment>

  <Section id="deep-dive" label="Deep dive" tag="article">
    <nav class="tb-sub__crumbs" aria-label="Breadcrumb">
      <ol class="tb-sub__crumblist">
        <li><a href="/" class="mono tb-sub__crumb">Home</a></li>
        <li aria-current="page"><span class="mono tb-sub__crumb tb-sub__crumb--current">{page.data.title}</span></li>
      </ol>
    </nav>
    <div class="tb-sub">
      <h1 class="display h2 tb-sub__title">{page.data.title}</h1>
      <p class="lede tb-sub__lede">{page.data.description}</p>
      <hr class="tb-sub__rule" />
      <div class="prose tb-sub__prose"><Content /></div>

      <SourceChips
        label="Sources cited on this page"
        sources={sources}
      />

      <div class="tb-sub__foot">
        <a href="/" class="btn ghost">&larr; Back to the single page</a>
        <a href="/citations" class="btn ghost">All citations &rarr;</a>
      </div>
    </div>
  </Section>
</Layout>

<style>
  .tb-sub { max-width: 72ch; }
  .tb-sub__title { margin: 0 0 20px; max-width: 24ch; }
  .tb-sub__lede { margin: 0 0 32px; }
  .tb-sub__rule {
    height: 1px;
    background: var(--rule);
    border: 0;
    margin: 0 0 32px;
  }
  .tb-sub__prose { max-width: none; }
  /* Hide the markdown's own H1 since we render it above in the shell */
  .tb-sub__prose :global(h1) { display: none; }
  .tb-sub__foot {
    margin-top: 56px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tb-sub__crumbs { margin-bottom: 24px; }
  .tb-sub__crumblist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }
  .tb-sub__crumblist li { display: inline-flex; align-items: center; }
  .tb-sub__crumblist li + li::before {
    content: '/';
    color: var(--ink-faint);
    margin-right: 12px;
  }
  .tb-sub__crumb {
    color: var(--ink-muted);
    text-decoration: none;
  }
  .tb-sub__crumb--current { color: var(--ink); }
  a.tb-sub__crumb:hover { color: var(--accent); }
</style>
