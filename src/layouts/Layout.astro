---
import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/base.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TriageModal from '../components/TriageModal.astro';
import TweaksPanel from '../components/TweaksPanel.astro';
import JsonLd from '../components/JsonLd.astro';
import { LAST_REVIEWED } from '../data/content';
import {
  buildOrganization,
  buildWebSite,
  buildLogo,
  buildOgImage,
  buildFaqPage,
  buildHomeCollectionPage,
  buildTemplatesHowToList,
} from '../lib/schema';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  /** When true, render FAQPage JSON-LD from the site's FAQ dataset. */
  faqSchema?: boolean;
  /** When true, emit a CollectionPage JSON-LD that describes the homepage
   *  as an index of the site's content. `dateModified` is pulled from
   *  LAST_REVIEWED in src/data/content.ts — bumping that constant on a
   *  content update also bumps the schema, which is the single point
   *  of truth we want. */
  collectionSchema?: boolean;
  /** When true, emit a HowTo ItemList describing every email template.
   *  Should only be true on the homepage where templates render. */
  templatesSchema?: boolean;
}

const { title, description, canonicalPath = '/', faqSchema = false, collectionSchema = false, templatesSchema = false } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://takealotback.com';
const canonical = `${siteUrl}${canonicalPath}`;

// JSON-LD — every page emits Organization + WebSite + Logo + ImageObject.
// Page-specific schema (FAQPage, CollectionPage, HowTo list) is opt-in
// via Props so non-home pages don't carry irrelevant blocks.
const organization = buildOrganization();
const website = buildWebSite();
const logo = buildLogo();
const ogImage = buildOgImage();

const faqPage = faqSchema
  ? buildFaqPage((await import('../data/content')).FAQ)
  : null;

const collectionPage = collectionSchema
  ? buildHomeCollectionPage({
      clauses: (await import('../data/content')).CLAUSES,
      templates: (await import('../data/content')).TEMPLATES,
    })
  : null;

const templatesHowTo = templatesSchema
  ? buildTemplatesHowToList((await import('../data/content')).TEMPLATES)
  : null;
---
<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Milk Moon Studio" />
    <meta name="publisher" content="Milk Moon Studio" />
    <meta name="content-language" content="en-ZA" />
    <meta name="geo.region" content="ZA" />
    <meta name="geo.placename" content="South Africa" />
    <meta name="last-reviewed" content={LAST_REVIEWED} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en-ZA" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="alternate" type="application/rss+xml" href={`${siteUrl}/rss.xml`} title="TakealotBack.com — deep dives" />
    <link rel="alternate" type="application/xml" href={`${siteUrl}/sitemap-index.xml`} title="Sitemap" />
    <link rel="alternate" type="text/plain" href={`${siteUrl}/llms.txt`} title="LLM summary" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="TakealotBack.com" />
    <meta property="og:locale" content="en_ZA" />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:secure_url" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="TakealotBack.com — TAKE A LOT BACK. South African consumer rights, dismantled." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
    <meta name="twitter:image:alt" content="TakealotBack.com — TAKE A LOT BACK. South African consumer rights, dismantled." />

    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#F3F1EC" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#141412" media="(prefers-color-scheme: dark)" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Fonts are self-hosted — see src/styles/fonts.css and the @fontsource-variable
        imports. No third-party origin (Google Fonts) in the critical path. */}

    {/* Baseline JSON-LD on every page */}
    <JsonLd data={organization} />
    <JsonLd data={website} />
    <JsonLd data={logo} />
    <JsonLd data={ogImage} />
    {faqPage && <JsonLd data={faqPage} />}
    {collectionPage && <JsonLd data={collectionPage} />}
    {templatesHowTo && <JsonLd data={templatesHowTo} />}
    <slot name="head" />

    {/* Tweaks: apply persisted data attributes before first paint to avoid flash.
        Palette 'auto' means "follow the OS prefers-color-scheme" — we set
        data-palette-source="system" so the dark-mode media query in tokens.css
        can take effect, and we also set an explicit data-palette to one of the
        concrete palettes so the cascade picks up the right colours even
        without the media query. */}
    <script is:inline>
      (function () {
        var DEFAULT = { palette: 'auto', display: 'geist', density: 'normal', hero: 'default' };
        var t;
        try {
          var raw = localStorage.getItem('tb_tweaks');
          t = raw ? JSON.parse(raw) : null;
          if (!t || typeof t !== 'object') t = null;
        } catch (e) { t = null; }
        if (!t) t = Object.assign({}, DEFAULT);
        for (var k in DEFAULT) if (!(k in t)) t[k] = DEFAULT[k];

        var r = document.documentElement;
        var paletteIsAuto = (t.palette === 'auto' || !t.palette);
        if (paletteIsAuto) {
          var prefersDark = false;
          try { prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches; } catch (e) {}
          r.setAttribute('data-palette', prefersDark ? 'carbon' : 'paper');
          r.setAttribute('data-palette-source', 'system');
        } else {
          r.setAttribute('data-palette', t.palette);
          r.setAttribute('data-palette-source', 'user');
        }
        r.setAttribute('data-display', t.display || 'geist');
        r.setAttribute('data-density', t.density || 'normal');
        r.setAttribute('data-hero', t.hero || 'default');

        // Live-react to OS theme changes when the user hasn't overridden.
        try {
          var mm = window.matchMedia('(prefers-color-scheme: dark)');
          var onChange = function (ev) {
            if (r.getAttribute('data-palette-source') !== 'system') return;
            r.setAttribute('data-palette', ev.matches ? 'carbon' : 'paper');
          };
          // Modern API; legacy `addListener` fallback kept for older Safari
          // (deprecation hint is expected).
          if (mm.addEventListener) mm.addEventListener('change', onChange);
          else if (mm.addListener) mm.addListener(onChange);
        } catch (e) { /* ignore */ }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <TriageModal />
    <TweaksPanel />

    {/* Global keyboard shortcuts + sticky-header scroll border + triage/tweaks toggles */}
    <script is:inline>
      (function () {
        var header = document.querySelector('[data-site-header]');
        if (header) {
          var update = function () {
            header.setAttribute('data-scrolled', window.scrollY > 20 ? 'true' : 'false');
          };
          update();
          window.addEventListener('scroll', update, { passive: true });
        }

        // Jump to a homepage anchor. If the user is currently on a deep-dive
        // or citation page, navigate to /#id; otherwise smooth-scroll in place.
        // Without this, all section shortcuts silently no-op'd off-home —
        // surprising for keyboard users coming back from a citation page.
        function jump(id) {
          var onHome = location.pathname === '/' || location.pathname === '/index.html';
          if (!onHome) {
            location.href = '/#' + id;
            return;
          }
          var el = document.getElementById(id);
          if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        window.addEventListener('keydown', function (e) {
          var target = e.target;
          if (target && target.matches && target.matches('input, textarea, select, [contenteditable]')) return;
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          var k = (e.key || '').toLowerCase();
          if (k === 'h') { jump('home'); return; }
          if (k === 'd') { jump('dismantled'); return; }
          if (k === 't') { jump('templates'); return; }
          if (k === 'l') { jump('law'); return; }
          if (k === 'w') { jump('warranties'); return; }
          if (k === 'e') { jump('escalate'); return; }
          if (k === 'f') { jump('faq'); return; }
          if (k === 's') { window.location.href = '/citations'; return; }
          if (k === 'c') {
            e.preventDefault();
            window.dispatchEvent(new CustomEvent('tb:triage-toggle'));
            return;
          }
          if (e.key === '?' || (e.shiftKey && k === '/')) {
            e.preventDefault();
            window.dispatchEvent(new CustomEvent('tb:tweaks-toggle'));
            return;
          }
          if (k === 'escape') {
            window.dispatchEvent(new CustomEvent('tb:triage-close'));
            window.dispatchEvent(new CustomEvent('tb:tweaks-close'));
          }
        });
      })();
    </script>
  </body>
</html>
